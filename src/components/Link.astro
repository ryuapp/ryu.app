---
interface Props {
  href: string;
  variant?: "default" | "dark" | "menu";
}

const cssDefault = "hover:underline";
const cssMenu = "text-center text-lg hover:underline hover:text-brand!";

const { href, variant = "default" } = Astro.props;
const customCss = variant === "default" ? cssDefault : cssMenu;
---

<a href={href} class="bg-transparent px-4 py-2 text-sm" class:list={customCss}>
  <slot />
</a>
